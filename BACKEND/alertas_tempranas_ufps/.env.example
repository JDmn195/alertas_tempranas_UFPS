# ============================================================
#  COPIA ESTE ARCHIVO COMO .env Y RELLENA TUS VALORES
#  cp .env.example .env  (Linux/Mac)
#  copy .env.example .env  (Windows)
# ============================================================

# --- Base de datos (Neon PostgreSQL) ---
DATABASE_URL=url_de_la_bd
DB_NAME=neondb
DB_USER=tu_usuario_aqui
DB_PASSWORD=tu_password_aqui
DB_HOST=tu_host_aqui.neon.tech
DB_PORT=5432

# --- Django ---
SECRET_KEY=genera-una-key-segura-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Configuración de Correo ---
# Para desarrollo: django.core.mail.backends.console.EmailBackend
# Para producción: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-password-de-aplicacion
DEFAULT_FROM_EMAIL=Alertas Tempranas UFPS <tu-correo@gmail.com>

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Supabase Storage ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-service-role-key-aqui
SUPABASE_BUCKET_NAME=evidencias
